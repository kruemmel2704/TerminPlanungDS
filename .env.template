FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your_secret_key_here
DATABASE_URL=sqlite:///database.db

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_id
DISCORD_CLIENT_SECRET=your_discord_secret
DISCORD_REDIRECT_URI=http://localhost:5000/callback/discord
DISCORD_BOT_TOKEN=your_bot_token # Erforderlich, um Rollen zu prüfen

# Discord Server Gating
DISCORD_GUILD_ID=your_guild_id
DISCORD_ADMIN_ROLE_ID=your_admin_role_id
DISCORD_USER_ROLE_ID=your_user_role_id # Optional: Wenn leer, darf jeder vom Server rein

# Google OAuth (Admin Calendar Only)
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
